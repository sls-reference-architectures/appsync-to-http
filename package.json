{
  "name": "appsync-to-http",
  "version": "1.0.0",
  "description": "Reference architecture to demonstrate AppSync to HTTP via VTL and IAM (acronym alert!)",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint '**.*.js' --fix",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "npx jest --testMatch '**/?(*.)+(unit.test).js'",
    "test:int": "npx jest --testMatch '**/?(*.)+(int.test).js' --config jest.config.int.js",
    "test:e2e": "npx jest --testMatch '**/?(*.)+(e2e.test).js' --config jest.config.int.js --detectOpenHandles",
    "deploy:http": "npx sls deploy --config serverless.http.yml --conceal",
    "deploy:gql": "npx sls deploy --config serverless.gql.yml --conceal",
    "teardown:gql": "npx sls remove --config serverless.gql.yml",
    "teardown:http": "npx sls remove --config serverless.http.yml",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sls-reference-architectures/appsync-to-http.git"
  },
  "author": "Seth Orell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sls-reference-architectures/appsync-to-http/issues"
  },
  "homepage": "https://github.com/sls-reference-architectures/appsync-to-http#readme",
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1081.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "async-retry": "^1.3.3",
    "aws-amplify": "^6.16.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-extended": "^4.0.2",
    "lint-staged": "^16.2.7",
    "osls": "^4.0.0",
    "prettier": "^3.8.1",
    "serverless-appsync-plugin": "^2.13.0",
    "serverless-esbuild": "^1.57.1",
    "serverless-iam-roles-per-function": "^3.2.0",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@aws-appsync/utils": "^2.0.3",
    "@aws-sdk/client-dynamodb": "^3.1058.0",
    "@aws-sdk/client-eventbridge": "^3.982.0",
    "@aws-sdk/lib-dynamodb": "^3.1043.0",
    "@aws-sdk/util-dynamodb": "^3.982.0",
    "@dazn/lambda-powertools-logger": "^1.28.1",
    "@middy/core": "^7.6.5",
    "@middy/http-error-handler": "^7.6.5",
    "@middy/http-event-normalizer": "^7.6.5",
    "@middy/http-json-body-parser": "^7.6.5",
    "@middy/input-output-logger": "^7.6.5",
    "aws4-axios": "^3.4.0",
    "aws4fetch": "^1.0.20",
    "axios": "^1.16.0",
    "ulid": "^3.0.2"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,mjs,md,ts}": "prettier --write --ignore-path .gitignore"
  }
}
